{
    "version": 2,
    "functions": {
        "api/server.ts": {
            "runtime": "vercel-node@latest"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/server.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}